      "paragraph": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "Complete development of Youniverse, a modular web application for creating personal multidimensional profiles across 7 chakra-inspired categories. The MVP includes full CRUD functionality, multiple export formats (JSON/Markdown/PDF), sharing capabilities with QR codes, responsive UI with dark/light modes, and local data persistence. The application was successfully built and prepared for deployment.",
              "link": null
            },
            "annotations": {
              "bold": false,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
            },
            "plain_text": "Complete development of Youniverse, a modular web application for creating personal multidimensional profiles across 7 chakra-inspired categories. The MVP includes full CRUD functionality, multiple export formats (JSON/Markdown/PDF), sharing capabilities with QR codes, responsive UI with dark/light modes, and local data persistence. The application was successfully built and prepared for deployment.",
            "href": null
          }
        ],
        "icon": null,
        "color": "default"
      },
      "archived": false
