      },
      "has_children": false,
      "in_trash": false,
      "type": "paragraph",
      "paragraph": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "Yannick requested a comprehensive market valuation for a T3 apartment in Résidence des Castalies, Annecy, for purchase negotiation. Manus conducted detailed market analysis using comparable sales data, evaluating a 7th floor unit with architectural features and division potential. The analysis established a fair market value of €333,505 with a negotiation range of €316,829-€350,180, supported by three direct comparables within the same residence. A complete valuation report was produced and optimized for negotiation use.",
              "link": null
            },
            "annotations": {
              "bold": false,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
            },
            "plain_text": "Yannick requested a comprehensive market valuation for a T3 apartment in Résidence des Castalies, Annecy, for purchase negotiation. Manus conducted detailed market analysis using comparable sales data, evaluating a 7th floor unit with architectural features and division potential. The analysis established a fair market value of €333,505 with a negotiation range of €316,829-€350,180, supported by three direct comparables within the same residence. A complete valuation report was produced and optimized for negotiation use.",
            "href": null
          }
        ],
        "icon": null,
        "color": "default"
      },
      "archived": false
    },
