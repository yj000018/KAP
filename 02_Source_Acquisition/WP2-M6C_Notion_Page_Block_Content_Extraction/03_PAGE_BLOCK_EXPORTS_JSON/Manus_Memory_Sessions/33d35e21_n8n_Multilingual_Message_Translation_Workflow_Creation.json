        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "User requested creation of complete n8n workflow JSON for automated translation of non-French/English messages from WhatsApp/Telegram. Manus designed dual-translation system using DeepL and OpenAI with intelligent complexity assessment to avoid translating simple/understandable messages. Workflow includes language detection, complexity evaluation, dual translation with aggregation, and formatted delivery back to original chat with clear attribution.",
              "link": null
            },
            "annotations": {
