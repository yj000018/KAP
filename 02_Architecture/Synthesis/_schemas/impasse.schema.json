{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Impasse",
  "description": "A documented dead end, failed approach, or rejected option",
  "type": "object",
  "required": ["impasse_id", "title", "description", "why_failed"],
  "properties": {
    "impasse_id": {"type": "string", "pattern": "^IMP-[0-9]{3}$"},
    "title": {"type": "string"},
    "description": {"type": "string"},
    "domain": {"type": "string"},
    "why_failed": {"type": "string"},
    "what_was_tried": {"type": "string"},
    "what_replaced_it": {"type": "string"},
    "discovered_at": {"type": "string", "format": "date-time"},
    "source_fragments": {"type": "array", "items": {"type": "string"}},
    "related_thought_lines": {"type": "array", "items": {"type": "string"}},
    "related_decisions": {"type": "array", "items": {"type": "string"}},
    "severity": {"type": "string", "enum": ["blocker", "significant", "minor"]},
    "lesson_learned": {"type": "string"},
    "still_relevant": {"type": "boolean", "default": true}
  }
}
