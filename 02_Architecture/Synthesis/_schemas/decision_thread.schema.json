{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Decision Thread",
  "description": "A tracked decision through its lifecycle",
  "type": "object",
  "required": ["decision_id", "decision_title", "decision_text", "status", "decided_at"],
  "properties": {
    "decision_id": {"type": "string", "pattern": "^DEC-[0-9]{3}$"},
    "decision_title": {"type": "string"},
    "decision_text": {"type": "string"},
    "decision_type": {"type": "string", "enum": ["architecture", "workflow", "tooling", "source_policy", "gate_policy", "agent_role", "data_model", "security", "normalization", "merge_policy", "project_direction"]},
    "status": {"type": "string", "enum": ["proposed", "accepted", "active", "superseded", "rejected", "deprecated", "under_review"]},
    "decided_at": {"type": "string", "format": "date-time"},
    "decided_by": {"type": "string"},
    "source_fragments": {"type": "array", "items": {"type": "string"}},
    "rationale": {"type": "string"},
    "accepted_option": {"type": "string"},
    "rejected_options": {"type": "array", "items": {"type": "string"}},
    "tradeoffs": {"type": "string"},
    "risks": {"type": "string"},
    "supersedes": {"type": "array", "items": {"type": "string"}},
    "superseded_by": {"type": "string"},
    "related_thought_lines": {"type": "array", "items": {"type": "string"}},
    "current_validity": {"type": "string", "enum": ["valid", "partially_valid", "invalid", "under_review"]}
  }
}
